# ============================================
# Telegram Bot SaaS - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bot_saas
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@database:5432/bot_saas
DATABASE_URL_SYNC=postgresql://postgres:postgres@database:5432/bot_saas

# ============================================
# Redis Configuration
# ============================================
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379/0

# ============================================
# pgAdmin Configuration (Database UI)
# ============================================
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@botsaas.local
PGADMIN_PASSWORD=admin123

# ============================================
# Redis Commander Configuration (Redis UI)
# ============================================
REDIS_COMMANDER_PORT=8082

# ============================================
# Platform Bot Configuration
# ============================================
PLATFORM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
PLATFORM_BOT_WEBHOOK_SECRET=your_secret_token_here
PLATFORM_BOT_USERNAME=your_bot_username

# ============================================
# Bot Factory Configuration
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock
BOT_TEMPLATE_IMAGE=telegram-bot-saas/bot-template:latest
BOT_CONTAINER_NETWORK=bot_saas_network

# ============================================
# Notification Service Configuration
# ============================================
NOTIFICATION_WORKER_CONCURRENCY=2
NOTIFICATION_CHECK_INTERVAL=300  # seconds (5 minutes)

# ============================================
# Billing Service Configuration
# ============================================
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_TEST_MODE=true

# ============================================
# Security Configuration
# ============================================
ENCRYPTION_KEY=generate_with_python_-_cryptography_fernet_generate_key
JWT_SECRET_KEY=generate_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin123

# ============================================
# API Gateway / nginx Configuration
# ============================================
SERVER_DOMAIN=api.yourdomain.com
SSL_CERT_PATH=/etc/letsencrypt/live/api.yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/api.yourdomain.com/privkey.pem

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text
LOG_FILE_PATH=/var/log/bot_saas

# ============================================
# Development Configuration
# ============================================
DEBUG=true
TEST_MODE=false
MOCK_PAYMENTS=true

# ============================================
# Web Panel Configuration
# ============================================
WEB_PANEL_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# ============================================
# Telegram Configuration
# ============================================
# @BotFather provides these tokens
# Get them at https://t.me/BotFather

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *  # Daily at 3 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups

# ============================================
# S3 Backup Configuration (Optional)
# ============================================
S3_BACKUP_ENABLED=false
S3_BUCKET_NAME=your-backup-bucket
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_ENDPOINT=https://s3.amazonaws.com
