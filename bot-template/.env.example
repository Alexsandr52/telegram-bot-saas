# ============================================
# Bot Template - Environment Variables
# For local testing
# ============================================

# Bot Configuration
BOT_ID=your-bot-uuid-here
BOT_TOKEN=your-bot-token-here

# ============================================
# Proxy Configuration (CRITICAL for Russia!)
# Telegram API is blocked in Russia - you MUST configure a proxy
# Options: socks5:// or http://
# Format: socks5://username:password@proxy-host:proxy-port
# ============================================
TELEGRAM_PROXY=socks5://username:password@proxy-host:proxy-port

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bot_saas
